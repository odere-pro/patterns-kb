{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(node scripts/kb.mjs:*)",
      "Bash(node scripts/build.mjs:*)",
      "Bash(node scripts/build-pages.mjs:*)",
      "Bash(node scripts/build-vocab.mjs:*)",
      "Bash(node scripts/build-hub.mjs:*)",
      "Bash(node scripts/build-graph-page.mjs:*)",
      "Bash(node scripts/build-claude.mjs:*)",
      "Bash(node scripts/check-links.mjs)",
      "Bash(node scripts/audit-relations.mjs)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-kb.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
